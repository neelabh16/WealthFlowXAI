# Copy the values below into:
# - backend/.env
# - frontend/.env.local
#
# The service-specific examples in backend/.env.example and frontend/.env.example
# are the authoritative files actually used by the app.

DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
APP_TIME_ZONE=Asia/Kolkata
CORS_ALLOWED_ORIGINS=http://localhost:3000
SQLITE_PATH=
REDIS_URL=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_BASE_URL=https://api.razorpay.com/v1

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/notifications/
